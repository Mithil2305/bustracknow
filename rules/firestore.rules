rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users are readable to signed-in clients for leaderboard/trust views,
    // but only owners can create/update themselves.
    match /users/{userId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && request.auth.uid == userId;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && (!request.resource.data.keys().hasAny(['isBanned'])
            || request.resource.data.isBanned == resource.data.isBanned)
        && !resource.data.isBanned;

      allow delete: if isAdmin();
    }

    match /routes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stops/{stopId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /alerts/{alertId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['routeId', 'type', 'contributorId', 'location', 'timestamp'])
        && ['full', 'late', 'not-running'].hasAny([request.resource.data.type])
        && request.resource.data.location.lat is number
        && request.resource.data.location.lng is number
        && request.resource.data.contributorId == request.auth.uid
        && request.resource.data.timestamp > (request.time - duration.value(5, 'minutes'))
        && !get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned;

      allow update: if isSignedIn() && request.resource.data.upvotes > resource.data.upvotes;
      allow delete: if isAdmin();
    }

    match /points_transactions/{transactionId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /redemptions/{requestId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.userId || isAdmin());

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.pointsUsed >= 10000
        && request.resource.data.amount >= 100
        && resource == null;

      allow update: if isAdmin()
        && request.resource.data.status in ['pending', 'processing', 'completed', 'failed'];

      allow delete: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
